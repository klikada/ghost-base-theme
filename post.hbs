{{!< default}} 
{{!-- {{!< default}} 
      The tag above means - insert everything in this file into the {body} of the default.hbs template --}}

<main class="main">
    {{!-- <main class="main"> The main content area on the single post --}}

    {{#post}}
    {{!-- {{#post}} Everything inside the #post tags pulls data from the page --}}

    <article class="{{post_class}}">
        {{!-- <article class="{{post_class}}"> --}}

        <header class="post-header">
            <div class="post-meta">
                {{#if featured}}
                <span class="post-featured-badge">Featured</span>
                {{!-- <span class="post-featured-badge">{{t "Featured"}}</span> --}}
                {{/if}}

                <time datetime="{{date format='YYYY-MM-DD'}}">{{date format="DD MMMM YYYY"}}</time>
                {{!-- <time datetime="{{date format='YYYY-MM-DD'}}">{{date format="DD MMMM YYYY"}}</time> --}}
            </div>

            <h1 class="post-title">{{title}}</h1>
            {{!-- <h1 class="post-title">{{title}}</h1> --}}

            <div class="post-byline">
                {{authors separator=", " prefix=(t "Ditulis oleh ")}}
                {{tags separator=", " prefix=(t " | Kategori: ")}}
            </div>
            {{!-- <div class="post-byline">
                    {{authors separator=", " prefix=(t "Posted by ")}}
                    {{tags separator=", " prefix=(t "in ")}}
                </div> --}}
            
            {{#if feature_image}}
                <figure class="post-image">
                    <img
                        src="{{img_url feature_image size="l" format="webp"}}"
                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{/if}}"
                    />
                    {{#if feature_image_caption}}
                        <figcaption>{{feature_image_caption}}</figcaption>
                    {{/if}}
                </figure>
                {{!-- <figure class="post-image"> ... </figure> --}}
            {{/if}}
        </header>

        {{#if access}}
            <div class="post-content">
                <h2>Selamat Datang di PKL Klik Ada 2025</h2>
                <p>
                    Program <strong>PKL Klik Ada 2025</strong> adalah kolaborasi antara
                    <em>SMKN 1 Boyolangu</em> yang bertujuan
                    untuk melatih keterampilan siswa dalam <strong>pengembangan web, desain UI/UX, dan manajemen proyek</strong>.
                </p>

                <h3>Tujuan Utama</h3>
                <ul>
                    <li>Menguasai pembuatan dan kustomisasi tema Ghost CMS</li>
                    <li>Belajar berkolaborasi melalui GitHub</li>
                    <li>Membangun portofolio digital sebagai bekal karir</li>
                </ul>

                <h3>Galeri Kegiatan</h3>
                <div class="gallery grid grid-cols-2 gap-4">
                    <img src="/assets/images/foto1.jpg" alt="Foto 1" class="rounded shadow">
                    <img src="/assets/images/foto2.jpg" alt="Foto 2" class="rounded shadow">
                </div>
            </div>
            {{!-- <div class="post-content">{{content}}</div> --}}

            <div class="post-share">
                <span class="post-share-title">Bagikan artikel ini:</span>
                <a target="_blank" href="https://twitter.com/intent/tweet?text={{encode title}}&amp;url={{url absolute="true"}}">X</a>
                <a target="_blank" href="https://www.facebook.com/sharer.php?u={{url absolute="true"}}">Facebook</a>
                <a target="_blank" href="https://www.linkedin.com/shareArticle?mini=true&url={{url absolute="true"}}&amp;title={{encode title}}&amp;source={{encode @site.title}}">LinkedIn</a>
            </div>
            {{!-- <div class="post-share"> ... </div> --}}

            <div class="author-box">
                {{#foreach authors}}
                    <div class="author-profile">
                        {{#if profile_image}}
                            <div class="author-image">
                                <img src="{{img_url profile_image size="xs" format="webp"}}" alt="{{name}}" />
                            </div>
                        {{/if}}
                        <div class="author-details">
                            <h2 class="author-title">Tentang <a href="{{url}}">{{name}}</a></h2>
                            {{#if bio}}
                            <p class="author-bio">{{bio}}</p>
                            {{/if}}
                        </div>
                    </div>
                {{/foreach}}
            </div>
            {{!-- <div class="author-box"> ... </div> --}}

            {{#if @custom.enable_disqus}}
                {{#if @custom.disqus_shortname}}
                    {{> "comments-disqus"}}
                {{/if}}
            {{else}}
                {{#if comments}}
                    {{> comments}}
                {{/if}}
            {{/if}}
        {{/if}}
    </article>
    {{!-- </article> --}}

    {{/post}}
    {{!-- {{/post}} --}}
</main>
{{!-- </main> --}}
